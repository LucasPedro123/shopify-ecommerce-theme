{% stylesheet %}

/* ═══════════════════════════════════════════════════════════
   DRAWER (mobile)
   ═══════════════════════════════════════════════════════════ */
.header__drawer {
  --header-drawer-min-height: 60px;
  display: flex;
  min-height: var(--header-drawer-min-height);
  align-items: center;
}

#header-component[data-menu-style='drawer'] .header__drawer {
  display: flex;
  min-height: var(--header-drawer-min-height);
}

@media screen and (min-width: 750px) {
  #header-component[data-menu-style='menu'] .header__drawer {
    display: none;
    min-height: 0;
  }
}

.header--compact .header__drawer {
  min-height: var(--minimum-touch-target);
}

/* ═══════════════════════════════════════════════════════════
   NAVIGATION BAR (faixa mobile)
   ═══════════════════════════════════════════════════════════ */
.menu-list--mobile {
  &.menu-list { display: grid; }
  & .menu-list__list { width: max-content; margin-inline: auto; gap: var(--menu-horizontal-gap); }
  & li { width: max-content; padding-block: var(--padding-sm); }
  & li:first-of-type { padding-inline-start: var(--menu-horizontal-gap); }
  & li:last-of-type  { padding-inline-end:   var(--menu-horizontal-gap); }
  & a { color: var(--color-foreground); }
}

.menu-list__scroll-container {
  position: relative;
  overflow-x: auto;
  mask-image: linear-gradient(to right, transparent, #000 20px, #000 calc(100% - 20px), transparent);
  padding-block: var(--padding-2xs);
}

/* ═══════════════════════════════════════════════════════════
   HEADER-MENU (custom element)
   ═══════════════════════════════════════════════════════════ */

/*
 * O tema força display:flex no custom element quando está no modo menu.
 * Mantemos display:block para que nosso flex interno (hdm-nav) funcione.
 */
#header-component .header-menu,
#header-component[data-menu-style='menu'] .header-menu {
  display: block !important;
  width: 100%;
}

@media screen and (max-width: 749px) {
  #header-component .header-menu { display: none !important; }
}

.header-menu__inner {
  width: 100%;
  height: 100%;
}

/* ═══════════════════════════════════════════════════════════
   HDM NAV — barra horizontal com scroll e setas
   ═══════════════════════════════════════════════════════════ */
.hdm-nav {
  display: flex;
  align-items: center;
  width: 100%;
  height: 44px;
}

/* Wrapper que clipa o overflow do track */
.hdm-nav__track-wrapper {
  flex: 1 1 0;
  min-width: 0;
  overflow: hidden;
  display: flex;
  justify-content: center;
  height: 100%;
}

/* A lista scrollável */
.hdm-nav__track {
  display: flex;
  align-items: center;
  height: 100%;
  overflow-x: auto;
  overflow-y: visible;
  scroll-behavior: smooth;
  scrollbar-width: none;
  -ms-overflow-style: none;
  justify-content: flex-start;

  &::-webkit-scrollbar { display: none; }
}

/* Cada item */
.hdm-nav__item {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  height: 100%;
  position: relative;
}

/* O link de topo */
.hdm-nav__link {
  display: flex;
  align-items: center;
  height: 100%;
  text-decoration: none;
  position: relative;
  white-space: nowrap;

  /* Indicador sublinhado */
  &::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 12px;
    right: 12px;
    height: 2px;
    background-color: #383838;
    transform: scaleX(0);
    transition: transform 0.2s ease;
    transform-origin: left center;
  }

  &:hover::after,
  &.hdm-nav__link--active::after,
  &[aria-expanded='true']::after {
    transform: scaleX(1);
  }
}

/* Texto do link */
.hdm-nav__link-text {
  font-weight: 400;
  font-size: 0.875rem;
  text-transform: uppercase;
  letter-spacing: 0.03em;
  color: #383838;
  white-space: nowrap;
  padding: 0 12px;
}

/* Grupo de setas — fixo à direita */
.hdm-nav__arrows {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  height: 100%;
  gap: 2px;
  padding-left: 4px;
}

/* Botões de seta */
.hdm-nav__arrow {
  flex-shrink: 0;
  background: none;
  border: none;
  cursor: pointer;
  font-size: 1.25rem;
  line-height: 1;
  color: #383838;
  padding: 0 4px;
  display: flex;
  align-items: center;
  height: 100%;
  transition: opacity 0.15s;
  user-select: none;

  &:hover { opacity: 0.55; }
}

/* ═══════════════════════════════════════════════════════════
   MEGA MENU PANEL
   — o JS move este elemento para <body> (portal pattern),
     por isso usamos position:fixed (aplicado via JS).
     Aqui definimos só o visual.
   ═══════════════════════════════════════════════════════════ */
.hdm-mega {
  /* Oculto por padrão */
  display: none;
  background: #fff;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.10);
  border-top: 1px solid #eee;

  /* Animação de entrada suave */
  opacity: 0;
  transform: translateY(-6px);
  transition:
    opacity 0.18s ease,
    transform 0.18s ease;
}

.hdm-mega--open {
  display: block;
  opacity: 1;
  transform: translateY(0);
}

.hdm-mega__inner {
  max-width: var(--page-width, 1200px);
  margin: 0 auto;
  padding: 28px var(--section-padding-inline, 24px) 32px;
}

.hdm-mega__grid {
  width: 100%;
}

/* ═══════════════════════════════════════════════════════════
   MEGA MENU LIST — colunas de texto (sem imagens)
   ═══════════════════════════════════════════════════════════ */
.hdm-mega-list {
  display: flex;
  gap: 40px;
  flex-wrap: wrap;
  width: 100%;
}

.hdm-mega-list__column {
  display: flex;
  flex-direction: column;
  min-width: 110px;
}

/* Título da coluna (nível pai) */
.hdm-mega-list__parent-link {
  font-weight: 700;
  font-size: 0.9375rem;
  color: #111;
  text-decoration: none;
  margin-bottom: 10px;
  display: block;
  line-height: 1.3;

  &:hover { text-decoration: underline; }
}

/* Links filhos */
.hdm-mega-list__child-link {
  font-size: 0.875rem;
  color: #555;
  text-decoration: none;
  line-height: 1.5;
  display: block;
  padding: 2px 0;

  &:hover { color: #111; text-decoration: underline; }
}

/* Link "+ X mais" */
.hdm-mega-list__more {
  font-size: 0.8rem;
  color: #9B7FD4;
  margin-top: 6px;
  display: block;
  text-decoration: none;

  &:hover { text-decoration: underline; }
}

/* ═══════════════════════════════════════════════════════════
   BADGES
   ═══════════════════════════════════════════════════════════ */

/* Blog — gradiente animado */
.hdm-blink-wrapper.nav-blog {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  background: linear-gradient(110deg, #6ee2f5 0%, #f4e285 25%, #ff5e98 55%, #b100e8 100%);
  background-size: 200% 200%;
  animation: holoFlow 4s ease infinite;
  padding: 3px 10px;
  border-radius: 4px;
  font-size: 0.82rem;
  color: #000;
}

.hdm-blink-wrapper.nav-blog .hdm-blink-1 {
  color: #000;
  animation: none;
}

@keyframes holoFlow {
  0%   { background-position: 0% 50%; }
  50%  { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

/* Outlet — roxo estático */
.hdm-blink-wrapper.nav-outlet {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 5px;
  background-color: #9B7FD4;
  border: 1.5px solid #9B7FD4;
  border-radius: 4px;
  padding: 3px 10px;
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.3px;
  animation: none;
}

.hdm-blink-wrapper.nav-outlet .hdm-blink-1,
.hdm-blink-wrapper.nav-outlet .hdm-blink-2 {
  grid-area: unset;
  position: static;
  opacity: 1;
  visibility: visible;
  animation: none;
  color: #fff;
  font-weight: 700;
}

.hdm-blink-wrapper.nav-outlet .hdm-blink-1::after {
  content: ' ';
}

/* Dia das Mães */
.hdm-mothers-day-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background-color: #10261A;
  border: 1px solid #C29B57;
  min-width: 125px;
  height: 26px;
  position: relative;
  overflow: hidden;
  font-weight: 800;
  text-transform: uppercase;
  font-size: 10px;
  letter-spacing: 0.5px;
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
  padding: 0 5px;
  vertical-align: middle;
}

.hdm-md-text-1,
.hdm-md-text-2 {
  position: absolute;
  width: 100%;
  text-align: center;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  white-space: nowrap;
}

.hdm-md-text-1 { animation: mdToggleText1 4s infinite; }
.hdm-md-text-2 { animation: mdToggleText2 4s infinite; }

@keyframes mdToggleText1 {
  0%, 45%  { opacity: 1; color: #C29B57; }
  50%, 100% { opacity: 0; }
}

@keyframes mdToggleText2 {
  0%, 45%  { opacity: 0; }
  50%, 95% { opacity: 1; color: #FFFFFF; }
  100%     { opacity: 0; }
}

{% endstylesheet %}

{% schema %}
{
  "name": "t:names.menu",
  "tag": null,
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:settings.menu",
      "default": "main-menu"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "primary"
    },
    {
      "type": "header",
      "content": "t:content.typography"
    },
    {
      "type": "select",
      "id": "type_font_primary_size",
      "label": "t:settings.top_level_size",
      "options": [
        { "value": "0.625rem", "label": "10px" },
        { "value": "0.75rem",  "label": "12px" },
        { "value": "0.875rem", "label": "14px" },
        { "value": "1rem",     "label": "16px" },
        { "value": "1.125rem", "label": "18px" }
      ],
      "default": "1rem"
    },
    {
      "type": "select",
      "id": "menu_font_style",
      "label": "t:settings.submenu_size",
      "options": [
        { "value": "regular",       "label": "t:options.small"  },
        { "value": "inverse",       "label": "t:options.medium" },
        { "value": "inverse_large", "label": "t:options.large"  }
      ],
      "default": "inverse"
    },
    {
      "type": "select",
      "id": "type_font_primary_link",
      "label": "t:settings.font",
      "options": [
        { "value": "body",       "label": "t:options.body"       },
        { "value": "subheading", "label": "t:options.subheading" },
        { "value": "heading",    "label": "t:options.heading"    },
        { "value": "accent",     "label": "t:options.accent"     }
      ],
      "default": "heading"
    },
    {
      "type": "select",
      "id": "type_case_primary_link",
      "label": "t:settings.text_case",
      "options": [
        { "value": "none",      "label": "t:options.default"   },
        { "value": "uppercase", "label": "t:options.uppercase" }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "t:content.submenu_feature"
    },
    {
      "type": "select",
      "id": "menu_style",
      "label": "t:settings.media_type",
      "options": [
        { "value": "text",                  "label": "t:options.none"                 },
        { "value": "collection_images",     "label": "t:options.collection_images"    },
        { "value": "featured_products",     "label": "t:options.featured_products"    },
        { "value": "featured_collections",  "label": "t:options.featured_collections" }
      ],
      "default": "text"
    },
    {
      "type": "header",
      "content": "t:content.mobile_layout"
    },
    {
      "type": "checkbox",
      "id": "navigation_bar",
      "label": "t:settings.navigation_bar"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme_navigation_bar",
      "label": "t:settings.navigation_bar_color_scheme",
      "default": "primary",
      "visible_if": "{{ block.settings.navigation_bar }}"
    },
    {
      "type": "checkbox",
      "id": "drawer_accordion",
      "label": "t:settings.accordion",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "drawer_accordion_expand_first",
      "label": "t:settings.expand_first_group",
      "default": false,
      "visible_if": "{{ block.settings.drawer_accordion == true }}"
    },
    {
      "type": "checkbox",
      "id": "drawer_dividers",
      "label": "t:settings.dividers",
      "default": false
    }
  ]
}
{% endschema %}
