{% doc %}
  @prompt
    Um layout editorial no estilo de revista
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-editorial-layout-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px;
  }

  .ai-editorial-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-editorial-featured-{{ ai_gen_id }} {
    grid-column: span 8;
    position: relative;
    overflow: hidden;
  }

  .ai-editorial-featured-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-editorial-featured-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 600px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-editorial-featured-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-editorial-featured-content-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: {{ block.settings.content_padding }}px;
    background: linear-gradient(to top, rgba(0,0,0,0.8), rgba(0,0,0,0));
    color: {{ block.settings.featured_text_color }};
  }

  .ai-editorial-featured-category-{{ ai_gen_id }} {
    font-family: {{ block.settings.category_font }};
    font-size: {{ block.settings.category_size }}px;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 12px;
    display: block;
    color: {{ block.settings.category_color }};
  }

  .ai-editorial-featured-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.featured_title_size }}px;
    line-height: 1.2;
    margin: 0 0 12px 0;
    font-weight: 700;
  }

  .ai-editorial-featured-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.excerpt_size }}px;
    line-height: 1.5;
    margin: 0;
    opacity: 0.9;
  }

  .ai-editorial-sidebar-{{ ai_gen_id }} {
    grid-column: span 4;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-editorial-article-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    background-color: {{ block.settings.article_bg_color }};
    border: {{ block.settings.article_border_width }}px solid {{ block.settings.article_border_color }};
  }

  .ai-editorial-article-image-{{ ai_gen_id }} {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
  }

  .ai-editorial-article-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 200px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-editorial-article-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 150px;
    max-height: 150px;
  }

  .ai-editorial-article-content-{{ ai_gen_id }} {
    padding: {{ block.settings.article_padding }}px;
  }

  .ai-editorial-article-category-{{ ai_gen_id }} {
    font-family: {{ block.settings.category_font }};
    font-size: {{ block.settings.article_category_size }}px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 8px;
    display: block;
    color: {{ block.settings.category_color }};
  }

  .ai-editorial-article-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.article_title_size }}px;
    line-height: 1.3;
    margin: 0 0 8px 0;
    font-weight: 600;
    color: {{ block.settings.article_text_color }};
  }

  .ai-editorial-article-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.article_excerpt_size }}px;
    line-height: 1.5;
    margin: 0;
    color: {{ block.settings.article_text_color }};
    opacity: 0.8;
  }

  .ai-editorial-divider-{{ ai_gen_id }} {
    height: {{ block.settings.divider_height }}px;
    background-color: {{ block.settings.divider_color }};
    margin: {{ block.settings.divider_margin }}px 0;
  }

  @media screen and (max-width: 989px) {
    .ai-editorial-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-editorial-featured-{{ ai_gen_id }},
    .ai-editorial-sidebar-{{ ai_gen_id }} {
      grid-column: span 1;
    }

    .ai-editorial-featured-placeholder-{{ ai_gen_id }} {
      height: 400px;
    }

    .ai-editorial-featured-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.featured_title_size }}px * 0.7);
    }

    .ai-editorial-article-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.article_title_size }}px * 0.9);
    }
  }
{% endstyle %}

<div class="ai-editorial-layout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-editorial-container-{{ ai_gen_id }}">
    <article class="ai-editorial-featured-{{ ai_gen_id }}">
      {% if block.settings.featured_image %}
        <img
          src="{{ block.settings.featured_image | image_url: width: 1600 }}"
          alt="{{ block.settings.featured_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.featured_image.width }}"
          height="{{ block.settings.featured_image.height }}"
          class="ai-editorial-featured-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-editorial-featured-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
      
      <div class="ai-editorial-featured-content-{{ ai_gen_id }}">
        {% if block.settings.featured_category != blank %}
          <span class="ai-editorial-featured-category-{{ ai_gen_id }}">{{ block.settings.featured_category }}</span>
        {% endif %}
        
        {% if block.settings.featured_title != blank %}
          <h2 class="ai-editorial-featured-title-{{ ai_gen_id }}">{{ block.settings.featured_title }}</h2>
        {% endif %}
        
        {% if block.settings.featured_excerpt != blank %}
          <p class="ai-editorial-featured-excerpt-{{ ai_gen_id }}">{{ block.settings.featured_excerpt }}</p>
        {% endif %}
      </div>
    </article>

    <aside class="ai-editorial-sidebar-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign image_key = 'article_' | append: i | append: '_image'
          assign category_key = 'article_' | append: i | append: '_category'
          assign title_key = 'article_' | append: i | append: '_title'
          assign excerpt_key = 'article_' | append: i | append: '_excerpt'
          
          assign article_image = block.settings[image_key]
          assign article_category = block.settings[category_key]
          assign article_title = block.settings[title_key]
          assign article_excerpt = block.settings[excerpt_key]
        %}
        
        <article class="ai-editorial-article-{{ ai_gen_id }}">
          {% if article_image %}
            <img
              src="{{ article_image | image_url: width: 600 }}"
              alt="{{ article_image.alt | escape }}"
              loading="lazy"
              width="{{ article_image.width }}"
              height="{{ article_image.height }}"
              class="ai-editorial-article-image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-editorial-article-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
          
          <div class="ai-editorial-article-content-{{ ai_gen_id }}">
            {% if article_category != blank %}
              <span class="ai-editorial-article-category-{{ ai_gen_id }}">{{ article_category }}</span>
            {% endif %}
            
            {% if article_title != blank %}
              <h3 class="ai-editorial-article-title-{{ ai_gen_id }}">{{ article_title }}</h3>
            {% endif %}
            
            {% if article_excerpt != blank %}
              <p class="ai-editorial-article-excerpt-{{ ai_gen_id }}">{{ article_excerpt }}</p>
            {% endif %}
          </div>
        </article>
        
        {% if i < 3 and block.settings.show_dividers %}
          <div class="ai-editorial-divider-{{ ai_gen_id }}"></div>
        {% endif %}
      {% endfor %}
    </aside>
  </div>
</div>

{% schema %}
{
  "name": "Layout editorial",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Artigo em destaque"
    },
    {
      "type": "image_picker",
      "id": "featured_image",
      "label": "Imagem"
    },
    {
      "type": "text",
