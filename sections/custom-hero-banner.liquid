{{ 'section-custom-hero.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  ═══════════════════════════════════════════════════════════════
  HDM BEAUTY — Hero Banner com Countdown Timer por Slide
  Cada block (slide) tem seu próprio countdown independente.
  ═══════════════════════════════════════════════════════════════
{%- endcomment -%}

<div
  class="custom-hero-wrapper page-width"
  data-autoplay="{{ section.settings.autoplay }}"
  data-speed="{{ section.settings.speed | times: 1000 }}"
>
  <div class="custom-hero-slider-container">
    <div class="custom-hero-slider" id="HeroSlider-{{ section.id }}">

      {%- for block in section.blocks -%}
        {%- liquid
          assign b            = block.settings
          assign has_cd       = b.show_countdown
          assign cd_end       = b.countdown_end
          assign cd_valid     = false
          if has_cd and cd_end != blank
            assign cd_valid = true
          endif
          assign cd_id = 'hdm-cd-' | append: block.id
        -%}

        <div class="custom-hero-slide" {{ block.shopify_attributes }}>

          {%- if b.link != blank -%}
            <a href="{{ b.link }}" class="custom-hero-link" aria-label="Ir para a promoção">
          {%- endif -%}

          {%- if b.image != blank -%}
            <picture>
              {%- if b.mobile_image != blank -%}
                <source media="(max-width: 749px)" srcset="{{ b.mobile_image | image_url: width: 750 }}">
              {%- endif -%}
              {{- b.image | image_url: width: 1920 | image_tag:
                  loading: 'lazy',
                  class: 'custom-hero-image',
                  alt: b.image.alt | default: 'Banner da loja'
              -}}
            </picture>
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg custom-hero-image' }}
          {%- endif -%}

          {%- if b.link != blank -%}
            </a>
          {%- endif -%}

          {%- comment -%} ── COUNTDOWN deste slide ── {%- endcomment -%}
          {%- if cd_valid -%}
            <div
              class="hdm-countdown"
              id="{{ cd_id }}"
              data-end="{{ cd_end }}"
              aria-label="Contador regressivo da oferta"
              style="
                left:   {{ b.countdown_x }};
                top:    {{ b.countdown_y }};
                transform: translate(
                  {%- if b.countdown_align_h == 'center' -%}-50%
                  {%- elsif b.countdown_align_h == 'right' -%}-100%
                  {%- else -%}0%{%- endif -%},
                  {%- if b.countdown_align_v == 'center' -%}-50%
                  {%- elsif b.countdown_align_v == 'bottom' -%}-100%
                  {%- else -%}0%{%- endif -%}
                );
                --cd-box:   {{ b.countdown_box_size }}px;
                --cd-num:   {{ b.countdown_num_size }}px;
                --cd-label: {{ b.countdown_label_size }}px;
                --cd-num-mobile: {{ b.countdown_num_size | times: 0.65 | round }}px;
              "
            >
              <div class="hdm-countdown__inner">
                <div class="hdm-countdown__unit" aria-live="polite">
                  <span class="hdm-countdown__num" data-unit="h">00</span>
                  <span class="hdm-countdown__label">Horas</span>
                </div>
                <span class="hdm-countdown__sep" aria-hidden="true">:</span>
                <div class="hdm-countdown__unit" aria-live="polite">
                  <span class="hdm-countdown__num" data-unit="m">00</span>
                  <span class="hdm-countdown__label">Minutos</span>
                </div>
                <span class="hdm-countdown__sep" aria-hidden="true">:</span>
                <div class="hdm-countdown__unit" aria-live="polite">
                  <span class="hdm-countdown__num" data-unit="s">00</span>
                  <span class="hdm-countdown__label">Segundos</span>
                </div>
              </div>
            </div>
          {%- endif -%}

        </div>
      {%- endfor -%}
    </div>

    {%- if section.blocks.size > 1 -%}
      <button class="custom-hero-arrow custom-hero-arrow--left" aria-label="Slide anterior">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>
      <button class="custom-hero-arrow custom-hero-arrow--right" aria-label="Próximo slide">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
    {%- endif -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <div class="custom-hero-controls">
      <div class="custom-hero-dots">
        {%- for block in section.blocks -%}
          <button
            class="custom-hero-dot {% if forloop.first %}is-active{% endif %}"
            aria-label="Ir para o slide {{ forloop.index }}"
            data-index="{{ forloop.index0 }}"
          ></button>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</div>

{%- comment -%} ── CSS GLOBAL DO COUNTDOWN (gerado uma vez) ── {%- endcomment -%}
<style>
  /* ── Posicionamento sobre o slide ── */
  .custom-hero-slide { position: relative; }

  .hdm-countdown {
    position: absolute;
    z-index: 10;
    pointer-events: none;
  }

  /* ── Layout interno ── */
  .hdm-countdown__inner {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  /* ── Caixa de cada unidade ── */
  .hdm-countdown__unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: rgba(20, 20, 20, 0.82);
    border-radius: 8px;
    padding: 10px 14px 8px;
    min-width: var(--cd-box, 72px);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  /* ── Número ── */
  .hdm-countdown__num {
    font-family: var(--font-heading--family, sans-serif);
    font-size: var(--cd-num, 40px);
    font-weight: 700;
    color: #ffffff;
    line-height: 1;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }

  /* ── Label ── */
  .hdm-countdown__label {
    font-family: var(--font-body--family, sans-serif);
    font-size: var(--cd-label, 11px);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.75);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-top: 4px;
    white-space: nowrap;
  }

  /* ── Separador : ── */
  .hdm-countdown__sep {
    font-family: var(--font-heading--family, sans-serif);
    font-size: var(--cd-num, 40px);
    font-weight: 700;
    color: #ffffff;
    line-height: 1;
    align-self: flex-start;
    padding-top: 10px;
    opacity: 0.8;
  }

  /* ── Expirado — esmaece ── */
  .hdm-countdown[data-expired] .hdm-countdown__inner {
    opacity: 0.35;
  }

  /* ── Mobile: reduz proporcionalmente ── */
  @media screen and (max-width: 749px) {
    .hdm-countdown__unit {
      min-width: 44px;
      padding: 6px 8px 5px;
    }
    .hdm-countdown__num,
    .hdm-countdown__sep {
      font-size: var(--cd-num-mobile, 26px);
    }
    .hdm-countdown__label {
      font-size: 8px;
    }
  }
</style>

<script src="{{ 'custom-hero.js' | asset_url }}" defer="defer"></script>

{%- comment -%} ── JS: inicializa um timer por countdown encontrado na página ── {%- endcomment -%}
<script>
(function () {
  'use strict';

  function pad(n) { return String(n).padStart(2, '0'); }

 function initCountdown(wrapper) {
  const endRaw = wrapper.dataset.end;
  if (!endRaw) return;

  // Força interpretação como horário LOCAL (não UTC)
  // Substitui o T por espaço — browsers interpretam "2025-05-15 23:59:00" como local
  const endDate = new Date(endRaw.replace('T', ' '));
  if (isNaN(endDate.getTime())) return;

  const elH = wrapper.querySelector('[data-unit="h"]');
  const elM = wrapper.querySelector('[data-unit="m"]');
  const elS = wrapper.querySelector('[data-unit="s"]');
  if (!elH || !elM || !elS) return;

  // Remove data-expired caso exista do SSR
  wrapper.removeAttribute('data-expired');

  function tick() {
    const diff = endDate.getTime() - Date.now();

    if (diff <= 0) {
      elH.textContent = '00';
      elM.textContent = '00';
      elS.textContent = '00';
      wrapper.setAttribute('data-expired', '');
      return;
    }

    const total = Math.floor(diff / 1000);
    elH.textContent = pad(Math.floor(total / 3600));
    elM.textContent = pad(Math.floor((total % 3600) / 60));
    elS.textContent = pad(total % 60);

    setTimeout(tick, 1000);
  }

  tick();
}

  // Inicializa todos os countdowns presentes no DOM
  function initAll() {
    document.querySelectorAll('.hdm-countdown[data-end]').forEach(initCountdown);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAll);
  } else {
    initAll();
  }
})();
</script>

{% schema %}
{
  "name": "Hero Banner Principal",
  "tag": "section",
  "class": "section background-white",
  "settings": [
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Habilitar transição automática",
      "default": true
    },
    {
      "type": "range",
      "id": "speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Tempo entre os slides",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 5,
      "settings": [
        {
          "type": "header",
          "content": "Imagens"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagem Desktop (Sugerido: 1920x387px)"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Imagem Mobile (Sugerido: 1080x1080px)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link do Banner"
        },
        {
          "type": "header",
          "content": "⏱ Countdown Timer"
        },
        {
          "type": "checkbox",
          "id": "show_countdown",
          "label": "Exibir countdown neste slide",
          "default": false
        },
        {
          "type": "text",
          "id": "countdown_end",
          "label": "Data e hora de término",
          "info": "Formato: 2025-05-15T23:59:00",
          "default": "2025-12-31T23:59:00"
        },
        {
          "type": "header",
          "content": "Posição"
        },
        {
          "type": "text",
          "id": "countdown_x",
          "label": "Posição horizontal (ex: 75% ou 900px)",
          "default": "75%",
          "info": "Distância da borda esquerda do banner."
        },
        {
          "type": "text",
          "id": "countdown_y",
          "label": "Posição vertical (ex: 50% ou 120px)",
          "default": "50%",
          "info": "Distância do topo do banner."
        },
        {
          "type": "select",
          "id": "countdown_align_h",
          "label": "Âncora horizontal",
          "options": [
            { "value": "left",   "label": "Esquerda" },
            { "value": "center", "label": "Centro"   },
            { "value": "right",  "label": "Direita"  }
          ],
          "default": "left"
        },
        {
          "type": "select",
          "id": "countdown_align_v",
          "label": "Âncora vertical",
          "options": [
            { "value": "top",    "label": "Topo"   },
            { "value": "center", "label": "Centro" },
            { "value": "bottom", "label": "Base"   }
          ],
          "default": "center"
        },
        {
          "type": "header",
          "content": "Visual"
        },
        {
          "type": "range",
          "id": "countdown_box_size",
          "label": "Largura de cada caixa (px)",
          "min": 50,
          "max": 140,
          "step": 2,
          "default": 72
        },
        {
          "type": "range",
          "id": "countdown_num_size",
          "label": "Tamanho do número (px)",
          "min": 20,
          "max": 80,
          "step": 2,
          "default": 40
        },
        {
          "type": "range",
          "id": "countdown_label_size",
          "label": "Tamanho do label (px)",
          "min": 8,
          "max": 20,
          "step": 1,
          "default": 11
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner Principal",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
