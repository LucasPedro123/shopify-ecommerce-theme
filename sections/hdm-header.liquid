{% comment %}
  ═══════════════════════════════════════════════════════════════════
  HDM BEAUTY — Header Principal
  Arquivo: sections/hdm-header.liquid

  Estrutura:
    ┌─────────────────────────────────────────────────────────┐
    │ .hdm-header__topbar   → logo | busca | cep | ações     │
    ├─────────────────────────────────────────────────────────┤
    │ .hdm-header__navbar   → mega menu desktop (some scroll) │
    └─────────────────────────────────────────────────────────┘

  Mobile: topbar com drawer hamburger + logo + ações
  ═══════════════════════════════════════════════════════════════════
{% endcomment %}

{%- liquid
  assign main_menu = linklists[section.settings.menu]
  assign sticky = section.settings.sticky_header
-%}

{% render 'hdm-announcement-bar' %}

{%- comment -%} Schema JSON-LD {%- endcomment -%}
<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {% if settings.logo %}"logo": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }},{% endif %}
    "url": {{ request.origin | json }}
  }
</script>

{%- comment -%} ── MODAL CEP ─────────────────────────────────────────────────── {%- endcomment -%}
<div class="hdm-cep-modal" id="hdm-cep-modal" role="dialog" aria-modal="true" aria-label="Informar CEP" hidden>
  <div class="hdm-cep-modal__backdrop" id="hdm-cep-backdrop"></div>
  <div class="hdm-cep-modal__box">
    <button class="hdm-cep-modal__close" id="hdm-cep-close" aria-label="Fechar">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    <p class="hdm-cep-modal__title">Informe seu CEP</p>
    <p class="hdm-cep-modal__sub">Para calcular frete e prazo de entrega</p>
    <div class="hdm-cep-modal__field">
      <input
        id="hdm-cep-input"
        class="hdm-cep-modal__input"
        type="text"
        inputmode="numeric"
        maxlength="9"
        placeholder="00000-000"
        aria-label="CEP"
      >
      <button class="hdm-cep-modal__btn" id="hdm-cep-save">Salvar</button>
    </div>
    <a
      class="hdm-cep-modal__link"
      href="https://buscacepinter.correios.com.br/app/endereco/index.php"
      target="_blank"
      rel="noopener"
      >Não sei meu CEP</a
    >
  </div>
</div>

{%- comment -%} ── HEADER ────────────────────────────────────────────────────── {%- endcomment -%}
<hdm-header
  class="hdm-header{% if sticky %} hdm-header--sticky{% endif %}"
  id="hdm-header"
  {% if sticky %}
    data-sticky
  {% endif %}
>
  {%- comment -%} ── TOPBAR ── {%- endcomment -%}
  <div class="hdm-header__topbar">
    <div class="hdm-header__topbar-inner">
      {%- comment -%} Hamburger — só mobile {%- endcomment -%}
      <div class="hdm-header__drawer-trigger">
        {%- render 'header-drawer', linklist: main_menu, data_header_drawer_type: 'mobile-drawer' -%}
      </div>

      {%- comment -%} Logo {%- endcomment -%}
      <a href="{{ routes.root_url }}" class="hdm-header__logo" aria-label="{{ shop.name }}">
        {%- if settings.logo != blank -%}
          {{-
            settings.logo
            | image_url: width: 200
            | image_tag: alt: shop.name, class: 'hdm-header__logo-img', loading: 'eager', fetchpriority: 'high'
          -}}
        {%- else -%}
          <span class="hdm-header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      {%- comment -%} Busca — desktop e mobile {%- endcomment -%}
      <form
        action="{{ routes.search_url }}"
        method="get"
        class="hdm-header__search"
        role="search"
      >
        <input type="hidden" name="type" value="product">
        <div class="hdm-header__search-wrap">
          <input
            class="hdm-header__search-input"
            type="search"
            name="q"
            placeholder="{{ section.settings.search_placeholder | default: 'O que você procura hoje?' }}"
            aria-label="Buscar produtos"
            autocomplete="off"
          >
          <button class="hdm-header__search-btn" type="submit" aria-label="Buscar">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
          </button>
        </div>
      </form>

      {%- comment -%} Ações direita {%- endcomment -%}
      <div class="hdm-header__actions">
        {%- comment -%} CEP {%- endcomment -%}
        <button class="hdm-header__action hdm-header__action--cep" id="hdm-cep-trigger" aria-label="Informar CEP">
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
          </svg>
          <span class="hdm-header__action-label" id="hdm-cep-label">Informar CEP</span>
        </button>

        {%- comment -%} Conta {%- endcomment -%}
        {%- if shop.customer_accounts_enabled -%}
          <a
            href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
            class="hdm-header__action"
            aria-label="{%- if customer -%}Minha conta{%- else -%}Entrar{%- endif -%}"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
            </svg>
            <span class="hdm-header__action-label">
              {%- if customer -%}Olá, {{ customer.first_name }}{%- else -%}Entrar{%- endif -%}
            </span>
          </a>
        {%- endif -%}

        {%- comment -%} Carrinho {%- endcomment -%}
        <a href="{{ routes.cart_url }}" class="hdm-header__action hdm-header__action--cart" aria-label="Carrinho">
          <span class="hdm-header__cart-wrap">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
            {%- if cart.item_count > 0 -%}
              <span class="hdm-header__cart-badge">{{ cart.item_count }}</span>
            {%- endif -%}
          </span>
        </a>
      </div>
      {%- comment -%} /.hdm-header__actions {%- endcomment -%}
    </div>
    {%- comment -%} /.hdm-header__topbar-inner {%- endcomment -%}
  </div>
  {%- comment -%} /.hdm-header__topbar {%- endcomment -%}

  {%- comment -%} ── NAVBAR (desktop) ── {%- endcomment -%}
  <div class="hdm-header__navbar" id="hdm-navbar">
    <div class="hdm-header__navbar-inner">
      <div class="hdm-nav__track-wrapper">
        <ul class="hdm-nav__track" role="list">
          {%- for link in main_menu.links -%}
            {%- liquid
              assign t = link.title | downcase
              assign has_sub = false
              if link.links != blank
                assign has_sub = true
              endif
            -%}
            <li
              class="hdm-nav__item"
              {% if has_sub %}
                data-has-submenu
              {% endif %}
            >
              <a
                href="{{ link.url }}"
                class="hdm-nav__link{% if link.active %} hdm-nav__link--active{% endif %}"
                {% if has_sub %}
                  aria-haspopup="true" aria-expanded="false"
                {% endif %}
                {% if link.current %}
                  aria-current="page"
                {% endif %}
              >
                {%- if t == 'blog' or t == 'blog loucas' -%}
                  <span class="hdm-badge hdm-badge--blog badge">{{ link.title }}</span>
                {%- elsif t == 'dia das mães' -%}
                  <span class="hdm-badge hdm-badge--maes badge" aria-label="Dia das Mães">
                    <span class="hdm-badge--maes__state hdm-badge--maes__state--presentes badge">
                      PRESENTES ATÉ&nbsp;<strong>40<sup>%</sup>OFF</strong>
                    </span>
                    <span class="hdm-badge--maes__state hdm-badge--maes__state--nome">
                      <span class="hdm-badge--maes__pre badge">DIA DAS</span>
                      <span class="hdm-badge--maes__main badge">MÃES</span>
                    </span>
                  </span>
                {%- elsif t == 'outlet' -%}
                  <span class="hdm-badge hdm-badge--outlet badge"> <span>Outlet</span> </span>
                {%- else -%}
                  {{- link.title -}}
                {%- endif -%}
              </a>

              {%- if has_sub -%}
                <div class="hdm-mega" role="region" aria-label="{{ link.title }}">
                  <div class="hdm-mega__inner">
                    <ul class="hdm-mega__list">
                      {%- for child in link.links -%}
                        <li class="hdm-mega__col">
                          <a href="{{ child.url }}" class="hdm-mega__parent-link">{{ child.title }}</a>
                          {%- if child.links != blank -%}
                            {%- assign max_visible = 8 -%}
                            <ul class="hdm-mega__children">
                              {%- for grandchild in child.links limit: max_visible -%}
                                <li>
                                  <a href="{{ grandchild.url }}" class="hdm-mega__child-link">{{ grandchild.title }}</a>
                                </li>
                              {%- endfor -%}
                            </ul>
                            {%- if child.links.size > max_visible -%}
                              {%- assign remaining = child.links.size | minus: max_visible -%}
                              <a href="{{ child.url }}" class="hdm-mega__more"
                                >+ {{ remaining }} em {{ child.title | downcase -}}
                              </a>
                            {%- endif -%}
                          {%- endif -%}
                        </li>
                      {%- endfor -%}
                    </ul>
                  </div>
                </div>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </div>

      <div class="hdm-nav__arrows" aria-hidden="true">
        <button class="hdm-nav__arrow hdm-nav__arrow--prev" type="button" tabindex="-1">&#8249;</button>
        <button class="hdm-nav__arrow hdm-nav__arrow--next" type="button" tabindex="-1">&#8250;</button>
      </div>
    </div>
    {%- comment -%} /.hdm-header__navbar-inner {%- endcomment -%}
  </div>
  {%- comment -%} /.hdm-header__navbar {%- endcomment -%}
  <div
    class="hdm-subheader-wrapper"
    style="background-color: {{ section.settings.subheader_bg_color }}; color: {{ section.settings.subheader_text_color }}; --subheader-height: {{ section.settings.height_subheader }}px"
  >
    <div class="page-width hdm-subheader__inner">
      <div class="hdm-subheader__item">
        <span class="hdm-subheader__text">{{ section.settings.subheader_text_1 }}</span>
        {%- if section.settings.subheader_link_1 != blank and section.settings.subheader_link_text_1 != blank -%}
          <a
            href="{{ section.settings.subheader_link_1 }}"
            class="hdm-subheader__link"
            style="color: {{ section.settings.subheader_text_color }};"
          >
            {{ section.settings.subheader_link_text_1 }}
          </a>
        {%- endif -%}
      </div>

      <div class="hdm-subheader__divider">
        <span style="color: {{ section.settings.subheader_text_color }}; background-color: transparent;">OU</span>
      </div>

      <div class="hdm-subheader__item">
        <span class="hdm-subheader__text">{{ section.settings.subheader_text_2 }}</span>
        {%- if section.settings.subheader_link_2 != blank and section.settings.subheader_link_text_2 != blank -%}
          <a
            href="{{ section.settings.subheader_link_2 }}"
            class="hdm-subheader__link"
            style="color: {{ section.settings.subheader_text_color }};"
          >
            {{ section.settings.subheader_link_text_2 }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</hdm-header>

{%- comment -%} ── OVERLAY do mega menu ─────────────────────────────────────── {%- endcomment -%}
<div class="hdm-mega-overlay" id="hdm-mega-overlay" aria-hidden="true"></div>

<script src="{{ 'hdm-header.js' | asset_url }}" defer></script>

{% stylesheet %}
    /* ═══════════════════════════════════════════════════════════
       HDM HEADER — Design Tokens
       ═══════════════════════════════════════════════════════════ */
    :root {
      --hdm-topbar-height:    72px;
      --hdm-navbar-height:    44px;
      --hdm-header-height:    calc(var(--hdm-topbar-height) + var(--hdm-navbar-height));

      --hdm-color-bg:         #ffffff;
      --hdm-color-border:     #ebebeb;
      --hdm-color-text:       #000;
      --hdm-color-text-muted: #6b7280;
      --hdm-color-accent:     #7c79e7;
      --hdm-color-outlet:     #9B7FD4;

      --hdm-search-radius:    24px;
      --hdm-page-max:         1280px;
      --hdm-page-padding:     clamp(16px, 4vw, 48px);

      --hdm-shadow-header:    0 2px 8px rgba(0,0,0,0.06);
      --hdm-shadow-mega:      0 8px 32px rgba(0,0,0,0.10);

      --hdm-transition-fast:  0.15s ease;
      --hdm-transition-base:  0.22s ease;
    }

    /* ═══════════════════════════════════════════════════════════
       RESET / BASE
       ═══════════════════════════════════════════════════════════ */
    hdm-header,
    .hdm-header__topbar,
    .hdm-header__navbar {
      display: block;
    }

    /* ═══════════════════════════════════════════════════════════
       HEADER WRAPPER
       ═══════════════════════════════════════════════════════════ */
    .hdm-header {
      background: var(--hdm-color-bg);
      box-shadow: var(--hdm-shadow-header);
      position: relative;
      z-index: 200;
    }

    .hdm-header--sticky {
      position: sticky;
      top: 0;
      display: flex;
      flex-direction: column;
      gap: 21px;
    }

    /* ═══════════════════════════════════════════════════════════
       TOPBAR
       ═══════════════════════════════════════════════════════════ */

       .badge{
          font-size: 20px !important;
       }

    .hdm-header__topbar-inner {
      max-width: var(--hdm-page-max);
      margin-inline: auto;
      padding-inline: var(--hdm-page-padding);
      height: var(--hdm-topbar-height);
      display: grid;
      grid-template-columns: auto 1fr auto;
      grid-template-areas: "logo search actions";
      align-items: center;
      gap: 24px;
    }

    /* Mobile: hamburger + logo + ações */
    @media screen and (max-width: 989px) {
      .hdm-header__topbar-inner {
        grid-template-columns: 44px 1fr auto;
        grid-template-areas: "drawer logo actions";
        gap: 12px;
        height: max-content;
      }
    }

    /* ── Logo ── */
    .hdm-header__logo {
        height: 100px;
      grid-area: logo;
      display: flex;
      align-items: center;
      text-decoration: none;
    }

    @media screen and (max-width: 989px) {
      .hdm-header__logo {
        justify-content: center;
      }
    }

    .hdm-header__logo-img {
      height: 60px;
      width: auto;
      object-fit: contain;
      display: block;
    }

    .hdm-header__logo-text {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--hdm-color-text);
    }

    /* ── Drawer trigger (mobile only) ── */
    .hdm-header__drawer-trigger {
      grid-area: drawer;
      display: none;
      align-items: center;
    }

    @media screen and (max-width: 989px) {
      .hdm-header__drawer-trigger {
        display: flex;
      }
    }

    /* ── Search ── */
    .hdm-header__search {
      grid-area: search;
    }

    @media screen and (max-width: 989px) {
      .hdm-header__search {
        display: none;
      }
    }

    .hdm-header__search-wrap {
      display: flex;
      align-items: center;
      background: #f4f4f6;
      border: 1.5px solid transparent;
      border-radius: var(--hdm-search-radius);
      transition: border-color var(--hdm-transition-fast), box-shadow var(--hdm-transition-fast);
      overflow: hidden;
    }

    .hdm-header__search-wrap:focus-within {
      border-color: var(--hdm-color-accent);
      box-shadow: 0 0 0 3px rgba(124,121,231,0.12);
      background: #fff;
    }

    .hdm-header__search-input {
      flex: 1;
      border: none;
      background: transparent !important;
      padding: 10px 16px;
      font-size: 0.9375rem;
      color: var(--hdm-color-text);
      outline: none;
      min-width: 0;
    }

    .hdm-header__search-input::placeholder {
      color: var(--hdm-color-text-muted);
    }

    .hdm-header__search-btn {
      flex-shrink: 0;
      background: none;
      border: none;
      padding: 10px 14px;
      cursor: pointer;
      color: var(--hdm-color-text-muted);
      display: flex;
      align-items: center;
      transition: color var(--hdm-transition-fast);
    }

    .hdm-header__search-btn:hover {
      color: var(--hdm-color-accent);
    }

    /* ── Actions ── */
    .hdm-header__actions {
      grid-area: actions;
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .hdm-header__action {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 8px 10px;
      border-radius: 8px;
      background: none;
      border: none;
      cursor: pointer;
      color: var(--hdm-color-text);
      text-decoration: none;
      font-size: 0.8125rem;
      font-weight: 500;
      transition: background var(--hdm-transition-fast), color var(--hdm-transition-fast);
      white-space: nowrap;
    }

    .hdm-header__action:hover {
      background: #f4f4f6;
      color: var(--hdm-color-accent);
    }

    .hdm-header__action-label {
      font-size: 0.8125rem;
    }

    /* Oculta labels de texto em telas pequenas */
    @media screen and (max-width: 989px) {
      .hdm-header__action-label {
        display: none;
      }

      .hdm-header__action--cep {
        display: none; /* CEP some no mobile — drawer tem outra UX */
      }
    }

    /* Carrinho */
    .hdm-header__cart-wrap {
      position: relative;
      display: flex;
      align-items: center;
    }

    .hdm-header__cart-badge {
      position: absolute;
      top: -8px;
      right: -8px;
      background: var(--hdm-color-accent);
      color: #fff;
      font-size: 0.6rem;
      font-weight: 700;
      min-width: 16px;
      height: 16px;
      border-radius: 99px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding-inline: 3px;
      line-height: 1;
    }

    /* ═══════════════════════════════════════════════════════════
       NAVBAR
       ═══════════════════════════════════════════════════════════ */
    .hdm-header__navbar {
      z-index: 6;
      background: var(--hdm-color-bg);
    }

    /* Esconde no mobile */
    @media screen and (max-width: 989px) {
      .hdm-header__navbar {
        display: none;
      }
    }

    /* Navbar some ao rolar (sticky = só topbar) */
    .hdm-header--sticky .hdm-header__navbar {
      transition: max-height var(--hdm-transition-base), opacity var(--hdm-transition-base), border-color var(--hdm-transition-base);
      max-height: var(--hdm-navbar-height);
      overflow: hidden;
      opacity: 1;
    }

    .hdm-header--sticky.hdm-header--scrolled .hdm-header__navbar {
      max-height: 0;
      opacity: 0;
      border-bottom-color: transparent;
    }

    .hdm-header__navbar-inner {
      max-width: var(--hdm-page-max);
      margin-inline: auto;
      padding-inline: var(--hdm-page-padding);
      height: var(--hdm-navbar-height);
      display: flex;
      align-items: center;
      gap: 0;
    }

    /* ── Track scrollável ── */
    .hdm-nav__track-wrapper {
      flex: 1 1 0;
      min-width: 0;
      overflow: hidden;
      height: 100%;
      display: flex;
      align-items: center;
    }

    .hdm-nav__track {
      display: flex;
      align-items: center;
      height: 100%;
      list-style: none;
      margin: 0;
      padding: 0;
      overflow-x: auto;
      overflow-y: visible;
      scroll-behavior: smooth;
      scrollbar-width: none;
      -ms-overflow-style: none;
      justify-content: flex-start;
    }

    .hdm-nav__track::-webkit-scrollbar { display: none; }

    /* ── Item ── */
    .hdm-nav__item {
      flex: 0 0 auto;
      display: flex;
      align-items: center;
      height: var(--hdm-navbar-height);
      position: relative;
    }

    /* ── Link topo ── */
    .hdm-nav__link {
      display: flex;
      align-items: center;
      height: 100%;
      padding-inline: 14px;
      font-size: 1.1rem;
      font-weight: 400;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--hdm-color-text);
      text-decoration: none;
      white-space: nowrap;
      position: relative;
      transition: color var(--hdm-transition-fast);
    }

    /* Sublinhado indicador */
    .hdm-nav__link::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 14px;
      right: 14px;
      height: 2px;
      background: var(--hdm-color-text);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform var(--hdm-transition-fast);
    }

    .hdm-nav__link:hover::after,
    .hdm-nav__link--active::after,
    .hdm-nav__link[aria-expanded="true"]::after {
      transform: scaleX(1);
    }

    /* ── Setas de scroll ── */
    .hdm-nav__arrows {
      flex: 0 0 auto;
      display: flex;
      align-items: center;
      gap: 2px;
      padding-left: 6px;
    }

    .hdm-nav__arrow {
      background: none;
      border: none;
      cursor: pointer;
      font-size: 1.4rem;
      line-height: 1;
      color: var(--hdm-color-text-muted);
      padding: 4px 5px;
      display: flex;
      align-items: center;
      transition: color var(--hdm-transition-fast), opacity var(--hdm-transition-fast);
      user-select: none;
    }

    .hdm-nav__arrow:hover { color: var(--hdm-color-text); }
    .hdm-nav__arrow:disabled { opacity: 0.25; cursor: default; }

    /* ═══════════════════════════════════════════════════════════
       MEGA MENU
       ═══════════════════════════════════════════════════════════ */

    /* O painel fica como filho do <li>.hdm-nav__item,
       mas é exibido como fixed via JS (portal pattern)
       para escapar do overflow:hidden do track-wrapper. */
    .hdm-mega {
      display: none;
      position: fixed;
      left: 0;
      right: 0;
      background: #fff;
      box-shadow: var(--hdm-shadow-mega);
      border-top: 1px solid var(--hdm-color-border);
      z-index: 199;
      opacity: 0;
      transform: translateY(-4px);
      transition: opacity var(--hdm-transition-fast), transform var(--hdm-transition-fast);
    }

    .hdm-mega--open {
      display: block;
      opacity: 1;
      transform: translateY(0);
    }

    .hdm-mega__inner {
      max-width: var(--hdm-page-max);
      margin-inline: auto;
      padding: 28px var(--hdm-page-padding) 32px;
    }

    /* Colunas */
    .hdm-mega__list {
      display: flex;
      flex-wrap: wrap;
      gap: 16px 40px;
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .hdm-mega__col {
      display: flex;
      flex-direction: column;
      min-width: 110px;
    }

    .hdm-mega__parent-link {
      font-size: 0.9375rem;
      font-weight: 700;
      color: #111;
      text-decoration: none;
      margin-bottom: 10px;
      display: block;
      line-height: 1.3;
    }

    .hdm-mega__parent-link:hover { text-decoration: underline; }

    .hdm-mega__children {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .hdm-mega__child-link {
      font-size: 0.875rem;
      color: #555;
      text-decoration: none;
      line-height: 1.5;
      display: block;
      padding-block: 2px;
    }

    .hdm-mega__child-link:hover { color: #111; text-decoration: underline; }

    .hdm-mega__more {
      font-size: 0.75rem;
      color: var(--hdm-color-accent);
      margin-top: 6px;
      display: block;
      text-decoration: none;
    }

    .hdm-mega__more:hover { text-decoration: underline; }

    /* Overlay escurece o conteúdo abaixo */
    /* Overlay escurece o conteúdo abaixo — fica ATRÁS do header */
    .hdm-mega-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.45);
      z-index: 198; /* abaixo do header (300) e do mega (199) */
      pointer-events: none;
      top: 0; /* começa do topo mas o header fica sobre ele pelo z-index */
    }

    .hdm-mega-overlay--visible {
      display: block;
    }

    /* ═══════════════════════════════════════════════════════════
       BADGES DE NAVEGAÇÃO
       ═══════════════════════════════════════════════════════════ */

    /* Blog — gradiente animado */
    .hdm-badge--blog {
      display: inline-flex;
      align-items: center;
      background: linear-gradient(110deg, #6ee2f5 0%, #f4e285 25%, #ff5e98 55%, #b100e8 100%);
      background-size: 200% 200%;
      animation: hdmHoloFlow 4s infinite;
      height: 36px;
      font-size: 0.9rem;
      padding-inline: 10px;
      font-weight: 800;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      color: #000;
    }

    @keyframes hdmHoloFlow {
      0%   { background-position: 0% 50%; }
      50%  { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    /* Outlet — roxo estático */
    .hdm-badge--outlet {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      background: var(--hdm-color-outlet);
      height: 36px;
      font-size: 0.9rem;
      padding-inline: 10px;
      font-weight: 700;
      letter-spacing: 0.3px;
      color: #fff;
    }
  /* Dia das Mães */
  .hdm-badge--maes {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 36px;
    padding-inline: 14px;
    white-space: nowrap;
    vertical-align: middle;
    position: relative;
    overflow: hidden;
    width: 276px;
    min-width: 200px;
    animation: hdmMaesBg 6s steps(1, end) infinite;
  }

  @keyframes hdmMaesBg {
    0%   { background: linear-gradient(135deg, #c9972a 0%, #e8b84b 50%, #b87d1a 100%); }
    50%  { background: linear-gradient(135deg, #2a1a2e 0%, #1a0d1e 60%, #0d0a0d 100%); }
  }

  .hdm-badge--maes__state {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding-inline: 14px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* Estado 1 — Presentes ATÉ 40% OFF */
  .hdm-badge--maes__state--presentes {
    font-size: 0.72rem;
    font-weight: 600;
    color: #fff;
    letter-spacing: 0.08em;
    animation: hdmMaesStatePresentes 6s steps(1, end) infinite;
  }

  .hdm-badge--maes__state--presentes strong {
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: 0.02em;
  }

  .hdm-badge--maes__state--presentes sup {
    font-size: 0.5rem;
    font-weight: 700;
    vertical-align: super;
  }

  @keyframes hdmMaesStatePresentes {
    0%   { opacity: 1; }
    50%  { opacity: 0; }
    100% { opacity: 1; }
  }

  /* Estado 2 — DIA DAS MÃES */
  .hdm-badge--maes__state--nome {
    gap: 6px;
    animation: hdmMaesStateNome 6s steps(1, end) infinite;
  }

  .hdm-badge--maes__pre {
    font-size: 0.72rem;
    font-weight: 400;
    color: #C29B57;
    letter-spacing: 0.12em;
  }

  .hdm-badge--maes__main {
    font-size: 1rem;
    font-weight: 800;
    color: #C29B57;
    letter-spacing: 0.06em;
  }

  @keyframes hdmMaesStateNome {
    0%   { opacity: 0; }
    50%  { opacity: 1; }
    100% { opacity: 0; }
  }


  /* Remove os antigos */
  .hdm-badge__text-1,
  .hdm-badge__text-2 { display: none; }

    /* ═══════════════════════════════════════════════════════════
       MODAL CEP
       ═══════════════════════════════════════════════════════════ */
    .hdm-cep-modal {
      position: fixed;
      inset: 0;
      z-index: 9999;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .hdm-cep-modal[hidden] { display: none; }

    .hdm-cep-modal__backdrop {
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,0.45);
    }

    .hdm-cep-modal__box {
      position: relative;
      background: #fff;
      border-radius: 16px;
      padding: 32px 28px 28px;
      width: min(92vw, 380px);
      box-shadow: 0 20px 60px rgba(0,0,0,0.18);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      text-align: center;
    }

    .hdm-cep-modal__close {
      position: absolute;
      top: 14px;
      right: 14px;
      background: none;
      border: none;
      cursor: pointer;
      color: #888;
      padding: 4px;
      display: flex;
      border-radius: 6px;
      transition: background var(--hdm-transition-fast);
    }

    .hdm-cep-modal__close:hover { background: #f4f4f6; color: #333; }

    .hdm-cep-modal__title {
      font-size: 1.1rem;
      font-weight: 700;
      color: #111;
      margin: 0;
    }

    .hdm-cep-modal__sub {
      font-size: 0.875rem;
      color: #666;
      margin: 0 0 8px;
    }

    .hdm-cep-modal__field {
      display: flex;
      gap: 8px;
      width: 100%;
    }

    .hdm-cep-modal__input {
      flex: 1;
      border: 1.5px solid #ddd;
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 1rem;
      outline: none;
      transition: border-color var(--hdm-transition-fast);
      text-align: center;
      letter-spacing: 0.05em;
    }

    .hdm-cep-modal__input:focus {
      border-color: var(--hdm-color-accent);
    }

    .hdm-cep-modal__btn {
      background: var(--hdm-color-accent);
      color: #fff;
      border: none;
      border-radius: 8px;
      padding: 10px 18px;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      transition: opacity var(--hdm-transition-fast);
    }

    .hdm-cep-modal__btn:hover { opacity: 0.88; }

    .hdm-cep-modal__link {
      font-size: 0.8rem;
      color: var(--hdm-color-accent);
      margin-top: 4px;
    }

    /* ═══════════════════════════════════════════════════════════
       ESPAÇADOR — evita conteúdo esconder atrás do header sticky
       ═══════════════════════════════════════════════════════════ */
    .hdm-header--sticky ~ * {
      /* nada — o sticky não tira do flow */
    }

    /* Offset de página quando sticky ativo */
    .hdm-header--sticky {
      /* Já está no flow, sem necessidade de margin adicional */
    }

    /* Sticky aplicado na <header> pai gerada pelo Shopify */
  .hdm-header-section {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 300;
    transition: transform 0.3s ease-in-out;
  }

  .hdm-header-section.hdm-header--hidden {
    transform: translateY(-100%);
  }

  /* Remove sticky do custom element — não é mais necessário */
  .hdm-header--sticky {
    position: relative;
  }

  /* Compensa o espaço que o fixed ocupa */
  body {
    padding-top: var(--hdm-header-fixed-height, 130px);
  }
{% endstylesheet %}

