{{ 'section-custom-collection-list.css' | asset_url | stylesheet_tag }}

<div class="custom-collection-wrapper page-width">
  
  <div class="custom-collection-header center">
    {%- if section.settings.title != blank -%}
      <h2 class="custom-collection-title">{{ section.settings.title }}</h2>
    {%- endif -%}
    
    {%- if section.settings.subtitle != blank -%}
      <p class="custom-collection-subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
      <a href="{{ section.settings.button_link }}" class="custom-secondary-btn">
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>

  <ul class="custom-collection-grid">
    {%- for block in section.blocks -%}
      <li class="custom-collection-item" {{ block.shopify_attributes }}>
        <a href="{{ block.settings.link }}" 
           class="custom-collection-card" 
           aria-label="Ver produtos da categoria {{ block.settings.title }}">
          
          <div class="custom-collection-image-wrap">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 600 | image_tag: 
                loading: 'lazy', 
                class: 'custom-collection-img',
                alt: block.settings.title | escape 
              }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg custom-collection-img' }}
            {%- endif -%}
            
            <div class="custom-collection-overlay"></div>
          </div>

          <div class="custom-collection-content">
            {%- if block.settings.title != blank -%}
              <h3 class="custom-collection-card-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            
            {%- if block.settings.action_text != blank -%}
              <span class="custom-collection-card-action">{{ block.settings.action_text }}</span>
            {%- endif -%}
          </div>
          
        </a>
      </li>
    {%- endfor -%}
  </ul>
</div>

{% schema %}
{
  "name": "Lista de Coleções Custom",
  "tag": "section",
  "class": "section mt-74px",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título da Seção",
      "default": "CONFIRA NOSSA COLEÇÃO"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Nossa Coleção Refrescante De Edição Limitada"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto do Botão",
      "default": "VER TUDO"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Link do Botão"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Coleção",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagem da Categoria (Sugerido: 390x316px)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título da Categoria",
          "default": "Nome da Categoria"
        },
        {
          "type": "text",
          "id": "action_text",
          "label": "Texto de Ação",
          "default": "Explorar"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link da Coleção"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lista de Coleções Custom",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}