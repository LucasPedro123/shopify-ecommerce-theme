{%- if section.settings.show_subheader -%}
  <div class="hdm-subheader-wrapper" style="background-color: {{ section.settings.subheader_bg_color }}; color: {{ section.settings.subheader_text_color }}; --subheader-height: {{ section.settings.height_subheader }}px">
    <div class="page-width hdm-subheader__inner">
      
      <div class="hdm-subheader__item">
        <span class="hdm-subheader__text">{{ section.settings.subheader_text_1 }}</span>
        {%- if section.settings.subheader_link_1 != blank and section.settings.subheader_link_text_1 != blank -%}
          <a href="{{ section.settings.subheader_link_1 }}" class="hdm-subheader__link" style="color: {{ section.settings.subheader_text_color }};">
            {{ section.settings.subheader_link_text_1 }}
          </a>
        {%- endif -%}
      </div>

      <div class="hdm-subheader__divider">
        <span style="color: {{ section.settings.subheader_text_color }}; background-color: transparent;">OU</span>
      </div>

      <div class="hdm-subheader__item">
        <span class="hdm-subheader__text">{{ section.settings.subheader_text_2 }}</span>
        {%- if section.settings.subheader_link_2 != blank and section.settings.subheader_link_text_2 != blank -%}
          <a href="{{ section.settings.subheader_link_2 }}" class="hdm-subheader__link" style="color: {{ section.settings.subheader_text_color }};">
            {{ section.settings.subheader_link_text_2 }}
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .hdm-subheader-wrapper {
    width: 100%;
    height: var(--subheader-height);
    padding: 8px 0;
    font-size: 12px;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1; 
  }
  
  .hdm-subheader__divider {
    font-size: 10px;
    font-weight: bold;
    padding: 0 10px;
  }

  /* Ajuste Mobile: empilha os itens se a tela for muito pequena */
  @media screen and (max-width: 749px) {
    .hdm-subheader-wrapper{
      display: none;
    }

    .hdm-subheader__inner {
      flex-direction: row;
      gap: 5px;
    }
    .hdm-subheader__divider {
      display: none; /* Esconder o "OU" no mobile para poupar espaço vertical costuma ser boa prática de UX */
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Subheader (Topo)",
  "tag": "header",
  "class": "section-subheader",
  "settings": [
    {
      "type": "range",
      "id": "height_subheader",
      "label": "Altura do subheader",
      "min": 20,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "checkbox",
      "id": "show_subheader",
      "label": "Exibir Subheader",
      "default": true
    },
    {
      "type": "color",
      "id": "subheader_bg_color",
      "label": "Cor de Fundo",
      "default": "#8b628b"
    },
    {
      "type": "color",
      "id": "subheader_text_color",
      "label": "Cor do Texto",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Bloco 1"
    },
    {
      "type": "text",
      "id": "subheader_text_1",
      "label": "Texto Principal 1",
      "default": "Frete grátis acima de R$199"
    },
    {
      "type": "text",
      "id": "subheader_link_text_1",
      "label": "Texto do Link 1",
      "default": "Ver regras"
    },
    {
      "type": "url",
      "id": "subheader_link_1",
      "label": "Link 1"
    },
    {
      "type": "header",
      "content": "Bloco 2"
    },
    {
      "type": "text",
      "id": "subheader_text_2",
      "label": "Texto Principal 2",
      "default": "10% OFF na primeira compra"
    },
    {
      "type": "text",
      "id": "subheader_link_text_2",
      "label": "Texto do Link 2",
      "default": "Pegar Cupom"
    },
    {
      "type": "url",
      "id": "subheader_link_2",
      "label": "Link 2"
    }
  ],
  "presets": [
    {
      "name": "Subheader (Topo)"
    }
  ]
}
{% endschema %}