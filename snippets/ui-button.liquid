{%- doc -%}
  ui-button — CVA-style button. Padrão visual da HDM:
   - Primary: pill brand-500, hover brand-600.
   - Secondary: outline preto/ink.
   - Outline: borda brand.
   - Ghost: transparente, sem borda.
   - Icon: quadrado arredondado 44/40px (botão de "add to bag").

  @param {string} [label]
  @param {string} [href]         - Se preenchido, renderiza <a>.
  @param {string} [type]         - 'button' | 'submit' | 'reset'. Default: 'button'.
  @param {string} [variant]      - 'primary' | 'secondary' | 'outline' | 'ghost' | 'icon-cart' | 'destructive'.
                                   Default: 'primary'.
  @param {string} [size]         - 'sm' | 'md' | 'lg' | 'icon'. Default: 'md'.
  @param {boolean} [full_width]
  @param {boolean} [disabled]
  @param {string} [aria_label]
  @param {string} [aria_expanded]
  @param {string} [aria_controls]
  @param {string} [target]
  @param {string} [rel]
  @param {string} [icon]         - Nome de snippet de ícone (esquerda).
  @param {string} [icon_right]
  @param {string} [extra_classes]
  @param {string} [id]

  @example
  {%- render 'ui-button', label: 'Comprar agora', variant: 'primary', size: 'lg' -%}
  {%- render 'ui-button', variant: 'icon-cart', aria_label: 'Adicionar ao carrinho' -%}
{%- enddoc -%}

{%- liquid
  assign _variant = variant | default: 'primary'
  assign _size = size | default: 'md'
  assign _type = type | default: 'button'

  assign base = 'tw-inline-flex tw-items-center tw-justify-center tw-gap-xs tw-font-sans tw-font-semibold tw-leading-tight tw-transition tw-duration-fast focus-visible:tw-outline-none focus-visible:tw-shadow-focus disabled:tw-opacity-50 disabled:tw-cursor-not-allowed tw-cursor-pointer tw-whitespace-nowrap'

  case _variant
    when 'primary'
      assign variant_cls = 'tw-bg-brand-500 tw-text-white hover:tw-bg-brand-600 tw-rounded-pill'
    when 'secondary'
      assign variant_cls = 'tw-bg-white tw-text-ink-900 tw-border tw-border-ink-200 hover:tw-bg-ink-50 tw-rounded-pill'
    when 'outline'
      assign variant_cls = 'tw-bg-transparent tw-text-brand-500 tw-border tw-border-brand-500 hover:tw-bg-brand-50 tw-rounded-pill'
    when 'ghost'
      assign variant_cls = 'tw-bg-transparent tw-text-ink-700 hover:tw-bg-ink-50 tw-rounded-md'
    when 'icon-cart'
      assign variant_cls = 'tw-bg-brand-500 tw-text-white hover:tw-bg-brand-600 tw-rounded-lg'
    when 'destructive'
      assign variant_cls = 'tw-bg-error tw-text-white hover:tw-opacity-90 tw-rounded-pill'
    else
      assign variant_cls = 'tw-bg-brand-500 tw-text-white hover:tw-bg-brand-600 tw-rounded-pill'
  endcase

  case _size
    when 'sm'
      assign size_cls = 'tw-text-sm tw-px-md tw-py-xs tw-min-h-[36px]'
    when 'lg'
      assign size_cls = 'tw-text-base tw-px-xl tw-py-md tw-min-h-[52px]'
    when 'icon'
      assign size_cls = 'tw-w-10 tw-h-10 tw-p-0'
    else
      assign size_cls = 'tw-text-sm tw-px-lg tw-py-sm tw-min-h-[44px]'
  endcase

  # icon-cart força size icon
  if _variant == 'icon-cart'
    assign size_cls = 'tw-w-11 tw-h-11 tw-p-0'
  endif

  assign width_cls = ''
  if full_width
    assign width_cls = 'tw-w-full'
  endif

  assign all_classes = base | append: ' ' | append: variant_cls | append: ' ' | append: size_cls | append: ' ' | append: width_cls
  if extra_classes != blank
    assign all_classes = all_classes | append: ' ' | append: extra_classes
  endif

  assign tag = 'button'
  if href != blank
    assign tag = 'a'
  endif
-%}

{%- if tag == 'a' -%}
  <a
    href="{{ href }}"
    class="{{ all_classes | strip_newlines }}"
    {%- if id != blank %} id="{{ id }}"{% endif -%}
    {%- if aria_label != blank %} aria-label="{{ aria_label | escape }}"{% endif -%}
    {%- if aria_expanded != blank %} aria-expanded="{{ aria_expanded }}"{% endif -%}
    {%- if aria_controls != blank %} aria-controls="{{ aria_controls }}"{% endif -%}
    {%- if target != blank %} target="{{ target }}"{% endif -%}
    {%- if target == '_blank' and rel == blank %} rel="noopener noreferrer"{% elsif rel != blank %} rel="{{ rel }}"{% endif -%}
    {%- if disabled %} aria-disabled="true" tabindex="-1"{% endif -%}
  >
    {%- if icon != blank -%}<span aria-hidden="true" class="tw-inline-flex">{%- render icon -%}</span>{%- endif -%}
    {%- if label != blank -%}<span>{{ label }}</span>{%- endif -%}
    {{ contents }}
    {%- if icon_right != blank -%}<span aria-hidden="true" class="tw-inline-flex">{%- render icon_right -%}</span>{%- endif -%}
  </a>
{%- else -%}
  <button
    type="{{ _type }}"
    class="{{ all_classes | strip_newlines }}"
    {%- if id != blank %} id="{{ id }}"{% endif -%}
    {%- if aria_label != blank %} aria-label="{{ aria_label | escape }}"{% endif -%}
    {%- if aria_expanded != blank %} aria-expanded="{{ aria_expanded }}"{% endif -%}
    {%- if aria_controls != blank %} aria-controls="{{ aria_controls }}"{% endif -%}
    {%- if disabled %} disabled aria-disabled="true"{% endif -%}
  >
    {%- if icon != blank -%}<span aria-hidden="true" class="tw-inline-flex">{%- render icon -%}</span>{%- endif -%}
    {%- if label != blank -%}<span>{{ label }}</span>{%- endif -%}
    {{ contents }}
    {%- if icon_right != blank -%}<span aria-hidden="true" class="tw-inline-flex">{%- render icon_right -%}</span>{%- endif -%}
  </button>
{%- endif -%}
