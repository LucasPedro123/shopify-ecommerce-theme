{%- doc -%}
  Renders mega menu list markup — text-only columns (no images).

  @param {object} parent_link - The linklist to render.
  @param {string} id          - Unique ID for the <ul>.
  @param {object} [section]   - The section object.
{%- enddoc -%}

<ul
  class="hdm-mega-list list-unstyled"
  data-menu-list-id="{{ id }}"
>
  {% for link in parent_link.links %}
    <li class="hdm-mega-list__column">
      <a href="{{ link.url }}" class="hdm-mega-list__parent-link">
        {{- link.title -}}
      </a>

      {% if link.links != blank %}
        {% assign max_visible = 8 %}
        {% assign total = link.links.size %}
        <ul class="list-unstyled">
          {% for childLink in link.links limit: max_visible %}
            <li>
              <a href="{{ childLink.url }}" class="hdm-mega-list__child-link">
                {{- childLink.title -}}
              </a>
            </li>
          {% endfor %}
        </ul>

        {% if total > max_visible %}
          {% assign remaining = total | minus: max_visible %}
          <a href="{{ link.url }}" class="hdm-mega-list__more">
            + {{ remaining }} {{ 'actions.more' | t | downcase }} {% if link.title != blank %}{{ link.title | downcase }}{% endif %}
          </a>
        {% endif %}
      {% endif %}
    </li>
  {% endfor %}
</ul>
