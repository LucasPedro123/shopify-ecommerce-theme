{%- doc -%}
  Renders the cart summary totals with Premium Checkout UI.
{%- enddoc -%}

<div class="cart-totals">
  <div class="cart-totals__original-container cart-primary-typography custom-summary-box">
     <div class="cart-summary__totals-grid" style="margin: 0px; padding-bottom: 0px;">
        <div class="cart-summary__totals-row">
          <span
            >Produto ({{ cart.item_count }}
            {% if cart.item_count == 1 %}item{% else %}itens{% endif %})</span
          >
          <div style="display:flex; gap:8px;">
            {% assign total_compare = 0 %}
            {% for item in cart.items %}
              {% if item.variant.compare_at_price > item.original_price %}
                {% assign compare_amount = item.variant.compare_at_price | times: item.quantity %}
                {% assign total_compare = total_compare | plus: compare_amount %}
              {% else %}
                {% assign original_amount = item.original_price | times: item.quantity %}
                {% assign total_compare = total_compare | plus: original_amount %}
              {% endif %}
            {% endfor %}

            {% if total_compare > cart.original_total_price %}
              <s style="color:#888;">{{ total_compare | money }}</s>
            {% endif %}
            <span>{{ cart.original_total_price | money }}</span>
          </div>
        </div>

        {%- if cart.total_discount > 0 or total_compare > cart.original_total_price -%}
          <div class="cart-summary__totals-row cart-summary__totals-row--discount">
            <span>Descontos</span>
            <span>
              {%- assign total_discount_calc = total_compare | minus: cart.total_price -%}
              - {{ total_discount_calc | money }}
            </span>
          </div>
        {%- endif -%}

        <div class="cart-summary__totals-row cart-summary__totals-row--subtotal">
          <strong>Subtotal</strong>
          <strong>{{ cart.total_price | money }}</strong>
        </div>
      </div>
  </div>
</div>

<div class="cart__ctas">
  <a
  id="checkout-bottom"
  class="cart__checkout-button button button--primary"
  href="{{ routes.cart_url }}"
>
  Finalizar Compra
  <svg
    viewBox="0 0 24 24"
    width="18"
    height="18"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    style="margin-left: 8px;"
  >
    <polyline points="9 18 15 12 9 6"></polyline>
  </svg>
</a>
   <div class="cart-summary__trust-badges" style="margin-top: 0px !important;">
        <a
          target="_blank"
          href="https://transparencyreport.google.com/safe-browsing/search?url=hdmbeauty.com.br"
        >
          <img
          src="{{ 'security-google-icon.svg' | asset_url }}"
          width="80"
          height="auto"
          alt="Site 100% Seguro"
          loading="lazy"
        >
        </a>
      </div>
</div>

<style>
  .custom-summary-box {
    background: #fcfcfc;
    border-radius: 12px;
    padding: 16px;
    margin-bottom: 16px;
    border: 1px solid #eaeaea;
  }
  .custom-summary-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }
  .custom-summary-row:last-child {
    margin-bottom: 0;
  }
  .custom-summary-label {
    font-size: 14px;
    color: #666;
  }
  .custom-summary-value {
    font-size: 14px;
    font-weight: 600;
    color: #111;
  }
  .discount-row {
    color: #166534;
  }
  .discount-label {
    display: flex;
    align-items: center;
    gap: 4px;
    color: #166534;
  }
  .discount-value {
    color: #166534;
  }
  .total-row {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px dashed #ccc;
  }
  .custom-summary-label-total {
    font-size: 16px;
    font-weight: 700;
    color: #000;
  }
  .custom-summary-value-total {
    font-size: 20px;
    font-weight: 800;
    color: #000;
  }

</style>
