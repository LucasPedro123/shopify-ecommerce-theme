{%- doc -%}
  ui-rating-stars — exibição de rating de 0 a 5 estrelas.

  Estratégia: renderiza 5 SVGs com `fill` percentual de acordo com
  `rating` (0–5). Suporta meia-estrela. Inclui aria-label completo
  ("4.5 de 5 estrelas, 127 avaliações") para acessibilidade.

  @param {number} rating       - 0 a 5. Aceita decimal (4.5).
  @param {number} [count]      - Número de avaliações (opcional).
  @param {string} [size]       - 'sm' | 'md' | 'lg'. Default: 'sm'.
  @param {boolean} [show_count] - Default: true se `count` fornecido.

  @example
  {%- render 'ui-rating-stars', rating: 4.5, count: 127 -%}
{%- enddoc -%}

{%- liquid
  assign _rating = rating | default: 0 | times: 1.0
  if _rating > 5
    assign _rating = 5
  elsif _rating < 0
    assign _rating = 0
  endif
  assign _size = size | default: 'sm'

  case _size
    when 'sm'
      assign star_px = 14
      assign text_cls = 'tw-text-2xs'
    when 'md'
      assign star_px = 18
      assign text_cls = 'tw-text-sm'
    else
      assign star_px = 22
      assign text_cls = 'tw-text-base'
  endcase

  assign aria_text = _rating | append: ' de 5 estrelas'
  if count != blank
    assign aria_text = aria_text | append: ', ' | append: count | append: ' avaliações'
  endif
-%}

<span class="tw-inline-flex tw-items-center tw-gap-2xs" aria-label="{{ aria_text }}" role="img">
  <span class="tw-inline-flex tw-items-center" aria-hidden="true">
    {%- for i in (1..5) -%}
      {%- assign fill_pct = _rating | minus: forloop.index0 | times: 100 | at_least: 0 | at_most: 100 -%}
      <svg width="{{ star_px }}" height="{{ star_px }}" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="flex-shrink:0;">
        <defs>
          <linearGradient id="star-grad-{{ section.id | default: 'sg' }}-{{ forloop.index }}">
            <stop offset="{{ fill_pct }}%" stop-color="#FACC15"/>
            <stop offset="{{ fill_pct }}%" stop-color="#E4E4E7"/>
          </linearGradient>
        </defs>
        <path d="M12 2l2.9 6.95 7.6.62-5.78 4.95 1.78 7.48L12 17.77 5.5 22l1.78-7.48L1.5 9.57l7.6-.62L12 2z" fill="url(#star-grad-{{ section.id | default: 'sg' }}-{{ forloop.index }})"/>
      </svg>
    {%- endfor -%}
  </span>
  {%- if count != blank and show_count != false -%}
    <span class="{{ text_cls }} tw-text-ink-500">({{ count }})</span>
  {%- endif -%}
</span>
